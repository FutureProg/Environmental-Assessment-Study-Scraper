# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @defaultRequired=infer @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# ----------

# Discord webhook URL for posting EA study notifications
# @required @sensitive @type=url
# @docs(https://discord.com/developers/docs/resources/webhook)
DISCORD_WEBHOOK_URL=

# PostgreSQL connection string for storing EA study snapshots
# @required @sensitive @type=url
DATABASE_URL=

# Anthropic API key for Claude — used to classify EA study scope
# @required @sensitive @type=string(startsWith=sk-ant-)
# @docs(https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=
